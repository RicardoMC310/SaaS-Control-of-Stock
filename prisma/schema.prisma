// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/Infrastructure/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRoles {
  UNASSOCIATED
  BOSS
  EMPLOYEE
}

model Users {
  ID           String      @id @default(cuid())
  name         String
  email        String      @unique
  passwordHash String
  role        UserRoles @default(UNASSOCIATED)
  // if EMPLOYEE
  companyID    String?
  company      Company?    @relation("EmployeeCompany", fields: [companyID], references: [ID], onUpdate: Cascade)
  // if BOSS
  ownedCompany Company?    @relation("BossCompany")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([email])
}

model Company {
  ID        String    @id @default(cuid())
  name      String    @unique
  // What`s peoples boss
  bossID    String    @unique
  boss      Users   @relation("BossCompany", fields: [bossID], references: [ID], onUpdate: Cascade)
  employees Users[] @relation("EmployeeCompany")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([name])
}
