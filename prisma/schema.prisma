generator client {
  provider = "prisma-client"
  output   = "../src/Infrastructure/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PeopleState {
  UNASSOCIATED
  BOSS
  EMPLOYEE
}

model Peoples {
  ID           Int         @id @default(autoincrement())
  name         String
  email        String      @unique
  passwordHash String
  state        PeopleState @default(UNASSOCIATED)
  // if EMPLOYEE
  companyID    Int?
  company      Company?    @relation("EmployeeCompany", fields: [companyID], references: [ID], onUpdate: Cascade)
  // if BOSS
  ownedCompany Company?    @relation("BossCompany")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Company {
  ID        Int       @id @default(autoincrement())
  name      String    @unique
  // What`s peoples boss
  bossID    Int       @unique
  boss      Peoples   @relation("BossCompany", fields: [bossID], references: [ID], onUpdate: Cascade)
  employees Peoples[] @relation("EmployeeCompany")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}
