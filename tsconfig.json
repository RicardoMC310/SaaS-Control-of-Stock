{
  "compilerOptions": {
    "baseUrl": "src",
    "target": "ES2020",
    "module": "CommonJS",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "paths": {
      "@routes/*": ["routes/*"],
      "@utils/*": ["utils/*"]
    }
  }
}
